# ============================================
# HappyImage 环境变量配置示例
# ============================================

# ── 认证密钥（必填）─────────────────────────────────────────────────
HAPPYIMAGE_AUTH_KEY=your_secret_key_here

# ── 服务地址 ────────────────────────────────────────────────────────
# HAPPYIMAGE_BASE_URL=https://your-domain.com
# HAPPYIMAGE_FRONTEND_BASE_URL=http://localhost:3000
# HAPPYIMAGE_API_BASE_URL=http://localhost:8000
# HAPPYIMAGE_CORS_ORIGINS=http://localhost:3000

# ── 会话配置（Web 登录 / OIDC 登录必需）──────────────────────────────
HAPPYIMAGE_SESSION_SECRET=generate-a-random-secret-at-least-32-chars
# HAPPYIMAGE_SESSION_COOKIE_NAME=happyimage_session
# HAPPYIMAGE_SESSION_MAX_AGE_SECONDS=86400

# ── OIDC 单点登录（可选）────────────────────────────────────────────
# HAPPYIMAGE_OIDC_ENABLED=true
# HAPPYIMAGE_OIDC_ISSUER=https://accounts.google.com
# HAPPYIMAGE_OIDC_CLIENT_ID=your-client-id
# HAPPYIMAGE_OIDC_CLIENT_SECRET=your-client-secret
# HAPPYIMAGE_OIDC_SCOPES=openid profile email
# HAPPYIMAGE_OIDC_ALLOWED_EMAIL_DOMAINS=your-domain.com
# HAPPYIMAGE_OIDC_DEFAULT_IMAGE_QUOTA=0

# ── 充值 / New API 对接（可选）────────────────────────────────────
# HAPPYIMAGE_RECHARGE_ENABLED=true
# HAPPYIMAGE_RECHARGE_PROVIDER=newapi
# HAPPYIMAGE_NEWAPI_BASE_URL=https://new-api.example.com
# HAPPYIMAGE_NEWAPI_CONSOLE_TOPUP_PATH=/console/topup
# HAPPYIMAGE_RECHARGE_WEBHOOK_SECRET=shared-secret-between-newapi-and-happyimage
# HAPPYIMAGE_RECHARGE_QUOTA_PER_UNIT=1

# Optional: route /api/image-tasks/* model calls through an OpenAI-compatible gateway such as NewAPI.
# HAPPYIMAGE_MODEL_GATEWAY_BASE_URL=http://localhost:3001/v1
# HAPPYIMAGE_MODEL_GATEWAY_API_KEY=sk-your-newapi-token

# ── 注册与代理 ──────────────────────────────────────────────────────
HAPPYIMAGE_REGISTRATION_ENABLED=true
# HAPPYIMAGE_PROXY=http://user:password@proxy.example.com:7890
# HAPPYIMAGE_PROXY=http://host.docker.internal:7897

# ── 图库 ────────────────────────────────────────────────────────────
HAPPYIMAGE_PREGENERATE_THUMBNAILS_ON_START=true
HAPPYIMAGE_THUMBNAIL_WIDTHS=640

# ── 基础镜像覆盖（可选）─────────────────────────────────────────────
# Docker Hub 拉取慢时可覆盖基础镜像源。阿里云官方加速通常是个人专属
# https://<your-id>.mirror.aliyuncs.com，需要在 Docker daemon 的 registry-mirrors 中配置。
# 中科大 mirror 可作为 Docker daemon mirror 尝试，但可能限制校外访问。
#
# 如果你已经把官方镜像同步到了自己的 ACR/内网仓库，也可以直接覆盖基础镜像：
# HAPPYIMAGE_NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
# HAPPYIMAGE_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.13-slim

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型（可选值: json, sqlite, postgres, git）
# 默认: json
STORAGE_BACKEND=json

# ============================================
# 数据库配置（当 STORAGE_BACKEND=sqlite/postgres 时使用）
# ============================================

# PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@localhost:5432/happyimage

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite 示例（不指定时自动使用 data/accounts.db）
# DATABASE_URL=sqlite:///app/data/accounts.db

# ============================================
# Git 仓库配置（当 STORAGE_BACKEND=git 时使用）
# ============================================

# Git 仓库地址（必填）
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git

# Git 访问令牌（必填）
# GitHub: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GitLab: glpat-xxxxxxxxxxxxxxxxxxxx
# GIT_TOKEN=your_git_token_here

# Git 分支（可选，默认: main）
# GIT_BRANCH=main

# Git 仓库中的文件路径（可选，默认: accounts.json）
# GIT_FILE_PATH=accounts.json
