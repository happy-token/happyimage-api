# ============================================
# Happy Token 环境变量配置示例
# ============================================

# ── 服务地址 ────────────────────────────────────────────────────────
# HAPPYTOKEN_BASE_URL=https://your-domain.com
# HAPPYTOKEN_FRONTEND_BASE_URL=http://localhost:3000
# HAPPYTOKEN_API_BASE_URL=http://localhost:8000
# HAPPYTOKEN_CORS_ORIGINS=http://localhost:3000

# ── 会话配置（Web 登录 / OIDC 登录必需）──────────────────────────────
HAPPYTOKEN_SESSION_SECRET=generate-a-random-secret-at-least-32-chars
# HAPPYTOKEN_SESSION_COOKIE_NAME=happytoken_session
# HAPPYTOKEN_SESSION_MAX_AGE_SECONDS=86400

# ── OIDC 单点登录（可选）────────────────────────────────────────────
# HAPPYTOKEN_OIDC_ENABLED=true
# HAPPYTOKEN_OIDC_ISSUER=https://accounts.google.com
# HAPPYTOKEN_OIDC_CLIENT_ID=your-client-id
# HAPPYTOKEN_OIDC_CLIENT_SECRET=your-client-secret
# HAPPYTOKEN_OIDC_SCOPES=openid profile email
# HAPPYTOKEN_OIDC_ALLOWED_EMAIL_DOMAINS=your-domain.com

# 图片生成供应商不在后端 .env 中配置。
# 普通用户在 Web 的“我的 -> 供应商”中保存并选择自己的 Base URL 和 API Key。

# ── 注册 ────────────────────────────────────────────────────────────
HAPPYTOKEN_REGISTRATION_ENABLED=true

# ── 基础镜像覆盖（可选）─────────────────────────────────────────────
# Docker Hub 拉取慢时可覆盖基础镜像源。阿里云官方加速通常是个人专属
# https://<your-id>.mirror.aliyuncs.com，需要在 Docker daemon 的 registry-mirrors 中配置。
# 中科大 mirror 可作为 Docker daemon mirror 尝试，但可能限制校外访问。
#
# 如果你已经把官方镜像同步到了自己的 ACR/内网仓库，也可以直接覆盖基础镜像：
# HAPPYTOKEN_NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
# HAPPYTOKEN_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.13-slim

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型。生产环境推荐 postgres。
STORAGE_BACKEND=postgres

# ============================================
# 数据库配置（当 STORAGE_BACKEND=postgres 时使用）
# ============================================

# PostgreSQL 示例
DATABASE_URL=postgresql://user:password@localhost:5432/happytoken

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres
