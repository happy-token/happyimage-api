# ============================================
# HappyImage infrastructure environment example
# ============================================
#
# Runtime application settings such as public URLs, session/cookie settings,
# OAuth/OIDC, NewAPI binding, model gateway URLs, image storage, proxy, and
# safety settings are managed in first-run /setup, admin /settings, or
# config.json.
# Keep deployment .env files focused on infrastructure.

# Host port for docker-compose.yml.
# HAPPYTOKEN_API_PORT=8000

# ── 基础镜像覆盖（可选）─────────────────────────────────────────────
# Docker Hub 拉取慢时可覆盖基础镜像源。阿里云官方加速通常是个人专属
# https://<your-id>.mirror.aliyuncs.com，需要在 Docker daemon 的 registry-mirrors 中配置。
# 中科大 mirror 可作为 Docker daemon mirror 尝试，但可能限制校外访问。
#
# 如果你已经把官方镜像同步到了自己的 ACR/内网仓库，也可以直接覆盖基础镜像：
# HAPPYTOKEN_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.13-slim

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型。默认 json 可直接配合 quickstart 启动；生产环境推荐 postgres。
STORAGE_BACKEND=json

# ============================================
# 数据库配置（当 STORAGE_BACKEND=postgres 时使用）
# ============================================

# 默认 json 存储不需要 DATABASE_URL。
DATABASE_URL=

# PostgreSQL 生产示例
# STORAGE_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/happyimage

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres
